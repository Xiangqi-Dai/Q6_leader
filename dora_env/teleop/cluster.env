# dora 0.5.0 分布式配置(纯 shell 变量)。
# 0.5.0 无 `dora cluster` 命令,分布式用 coordinator + daemon 组合,本文件被各脚本 source。

# 主臂机 = coordinator + 本地 daemon (machine=leader)
LEADER_IP=192.168.0.56
LEADER_USER=root

# 从臂机 = daemon (machine=follower), 连主臂 coordinator
FOLLOWER_IP=192.168.0.238
FOLLOWER_USER=root
FOLLOWER_SSH_PORT=20000      # 从臂 SSH 端口(非默认 22)

# dora 端口(0.5.0 默认)。主臂容器 host 网络,coordinator 监听 0.0.0.0,
# 故从臂可直连 LEADER_IP:$COORD_PORT,无需 Docker 端口映射。
COORD_PORT=53290
